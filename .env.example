# ======================================================
# Tempo 环境变量模板
# 复制为 .env 并填写真实值再运行 docker compose up -d
# ======================================================

# ── 数据库 ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_change_me          # MySQL root 密码
DB_NAME=tempo
DB_USER=tempo
DB_PASSWORD=tempo_change_me                 # 必填，tempo 用户密码

# ── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=                             # 无密码留空

# ── 微信小程序 ──────────────────────────────────────────
WX_APPID=your_wx_appid_here                 # 必填：微信小程序 AppID
WX_SECRET=your_wx_secret_here               # 必填：微信小程序 AppSecret
WX_TEMPLATE_ID=                             # 订阅消息模板 ID（不用提醒可留空）

# ── JWT ──────────────────────────────────────────────────
# 生产环境必须用随机强密钥，建议：openssl rand -hex 32
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-32-chars

# ── 开发旁路（生产必须删除或留空）────────────────────────
# 开发/测试时设置此值可绕过微信 jscode2session 接口，固定返回指定 openid
# 生产环境务必删除此行或留空，否则所有用户登录都会映射到同一账号
WX_MOCK_OPENID=

# ── AI 总结（可选）──────────────────────────────────────
AI_ENABLED=false
AI_API_KEY=
AI_API_URL=https://api.deepseek.com/v1/chat/completions
