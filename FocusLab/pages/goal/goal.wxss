.page { padding: 24rpx 24rpx 160rpx; }

.type-chips { display: flex; gap: 16rpx; margin-bottom: 20rpx; flex-wrap: wrap; }
.chip { padding: 12rpx 28rpx; border-radius: 40rpx; font-size: 26rpx; color: var(--color-text-sub); background: var(--color-card); border: 2rpx solid var(--color-border); }
.chip-active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }

.goal-card { padding: 24rpx; }

.goal-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; flex-wrap: wrap; }
.type-badge { padding: 4rpx 14rpx; border-radius: 6rpx; font-size: 22rpx; font-weight: bold; flex-shrink: 0; }
.type-1 { background: #E6F7FF; color: #1890FF; }
.type-2 { background: #F9F0FF; color: #722ED1; }
.type-3 { background: #FFF7E6; color: #FA8C16; }
.goal-title { flex: 1; font-size: 30rpx; font-weight: bold; color: var(--color-text); }
.status-badge { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 20rpx; flex-shrink: 0; }
.status-0 { background: #EEF4FF; color: var(--color-primary); }
.status-1 { background: #F6FFED; color: var(--color-success); }
.status-2 { background: #FFF1F0; color: var(--color-danger); }

.goal-desc { font-size: 26rpx; color: var(--color-text-sub); display: block; margin-bottom: 8rpx; }
.goal-date { font-size: 22rpx; color: var(--color-text-sub); display: block; margin-bottom: 12rpx; }

.progress-wrap { display: flex; align-items: center; gap: 16rpx; margin: 12rpx 0 4rpx; }
.progress-bar { flex: 1; height: 8rpx; background: var(--color-border); border-radius: 4rpx; overflow: hidden; }
.progress-fill { height: 100%; background: var(--color-primary); border-radius: 4rpx; }
.progress-text { font-size: 22rpx; color: var(--color-primary); width: 64rpx; text-align: right; flex-shrink: 0; }
.slider-wrap { margin: 0 -10rpx 8rpx; }

.finish-note { font-size: 22rpx; color: var(--color-text-sub); display: block; margin-top: 8rpx; font-style: italic; }

.goal-actions { display: flex; gap: 16rpx; margin-top: 16rpx; justify-content: flex-end; }
.action-btn { font-size: 24rpx; color: var(--color-primary); padding: 8rpx 16rpx; border-radius: 6rpx; background: #EEF4FF; }
.done-btn { color: var(--color-success); background: #F6FFED; }
.action-btn.danger { color: var(--color-danger); background: #FFF1F0; }

.fab { position: fixed; right: 40rpx; bottom: calc(120rpx + env(safe-area-inset-bottom)); width: 100rpx; height: 100rpx; border-radius: 50%; background: var(--color-primary); color: #fff; font-size: 60rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(26,115,232,0.4); z-index: 50; }

.modal-title { font-size: 32rpx; font-weight: bold; }
.modal-close { font-size: 36rpx; color: var(--color-text-sub); padding: 8rpx; }
