.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 120rpx 60rpx 80rpx;
  box-sizing: border-box;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: var(--color-text-sub);
  letter-spacing: 4rpx;
}

.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.login-btn {
  width: 100%;
  background: var(--color-primary);
  color: #fff;
  border-radius: 80rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(26,115,232,0.3);
  border: none;
}

.privacy-tip {
  font-size: 22rpx;
  color: var(--color-text-sub);
  text-align: center;
}
