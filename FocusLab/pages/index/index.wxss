.page { padding: 24rpx; }

.header { margin-bottom: 20rpx; }
.user-row { display: flex; align-items: center; gap: 20rpx; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: var(--color-border); flex-shrink: 0; }
.greeting { display: flex; flex-direction: column; gap: 4rpx; }
.nickname { font-size: 32rpx; font-weight: bold; color: var(--color-text); }
.date { font-size: 24rpx; color: var(--color-text-sub); }

.stat-card { }
.stat-row { display: flex; justify-content: space-around; align-items: center; margin-top: 20rpx; }
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.stat-num { font-size: 40rpx; font-weight: bold; color: var(--color-primary); }
.stat-label { font-size: 22rpx; color: var(--color-text-sub); }
.stat-divider { width: 1rpx; height: 60rpx; background: var(--color-border); }

.section-header { display: flex; justify-content: space-between; align-items: center; margin: 20rpx 0 12rpx; padding: 0 4rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: var(--color-text); }
.link { font-size: 24rpx; color: var(--color-primary); }

.todo-item { display: flex; align-items: center; gap: 20rpx; padding: 20rpx 24rpx; }
.check-circle { width: 44rpx; height: 44rpx; border-radius: 50%; border: 2rpx solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #fff; flex-shrink: 0; }
.check-circle.checked { background: var(--color-success); border-color: var(--color-success); }
.todo-content { flex: 1; min-width: 0; }
.todo-title { font-size: 28rpx; color: var(--color-text); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.done-text { text-decoration: line-through; color: var(--color-text-sub); }
.todo-meta { display: flex; align-items: center; gap: 12rpx; margin-top: 6rpx; }
.meta-text { font-size: 22rpx; color: var(--color-text-sub); }
.pri-dot { width: 12rpx; height: 12rpx; border-radius: 50%; }

.quick-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; margin-top: 24rpx; }
.quick-item { background: var(--color-card); border-radius: var(--radius-card); padding: 28rpx 0; display: flex; flex-direction: column; align-items: center; gap: 12rpx; box-shadow: var(--shadow-card); }
.quick-icon { font-size: 48rpx; }
.quick-label { font-size: 24rpx; color: var(--color-text-sub); }
