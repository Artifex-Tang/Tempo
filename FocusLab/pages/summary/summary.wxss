.page { padding: 24rpx; }

.tab-wrap { display: flex; background: var(--color-card); border-radius: 16rpx; padding: 8rpx; margin-bottom: 24rpx; box-shadow: var(--shadow-card); }
.tab-item { flex: 1; text-align: center; padding: 16rpx 0; font-size: 28rpx; color: var(--color-text-sub); border-radius: 12rpx; }
.tab-active { background: var(--color-primary); color: #fff; }

.period-label { font-size: 24rpx; color: var(--color-text-sub); display: block; margin-bottom: 20rpx; text-align: center; }

.metrics-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; margin-bottom: 20rpx; }
.metric-item { padding: 20rpx 12rpx; text-align: center; }
.metric-val { font-size: 36rpx; font-weight: bold; color: var(--color-primary); display: block; }
.metric-label { font-size: 22rpx; color: var(--color-text-sub); display: block; margin-top: 8rpx; }
.mini-bar { height: 6rpx; background: var(--color-border); border-radius: 3rpx; margin-top: 12rpx; overflow: hidden; }
.mini-fill { height: 100%; background: var(--color-primary); border-radius: 3rpx; transition: width 0.3s; }

.ai-card { margin-bottom: 20rpx; }
.ai-title { font-size: 26rpx; font-weight: bold; color: var(--color-text); display: block; margin-bottom: 12rpx; }
.ai-text { font-size: 26rpx; color: var(--color-text-sub); line-height: 1.7; display: block; }

.regen-btn { width: 100%; margin-top: 8rpx; font-size: 28rpx; }
