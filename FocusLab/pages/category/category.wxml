<view class="page">
  <view wx:if="{{loading}}" class="empty"><text>加载中...</text></view>
  <view wx:elif="{{categories.length === 0}}" class="empty"><text>暂无分类</text></view>
  <view wx:else class="list">
    <view wx:for="{{categories}}" wx:key="id" class="cat-item card">
      <view class="color-dot" style="background:{{item.color||'#1A73E8'}}"></view>
      <text class="cat-name">{{item.name}}</text>
      <view class="cat-actions">
        <text class="action-btn" bindtap="openEdit" data-item="{{item}}">编辑</text>
        <text class="action-btn danger" bindtap="removeCategory" data-id="{{item.id}}">删除</text>
      </view>
    </view>
  </view>

  <button class="btn-primary add-btn" bindtap="openCreate">+ 新建分类</button>

  <!-- 新建/编辑弹窗 -->
  <view wx:if="{{showModal}}">
    <view class="modal-mask" bindtap="closeModal"></view>
    <view class="modal-sheet">
      <view class="modal-header">
        <text class="modal-title">{{isEdit ? '编辑分类' : '新建分类'}}</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="field">
          <text class="field-label">名称 *</text>
          <input class="field-input" value="{{form.name}}" placeholder="分类名称（最多50字）" bindinput="onNameInput" maxlength="50" />
        </view>
        <view class="field">
          <text class="field-label">颜色</text>
          <view class="color-grid">
            <view wx:for="{{colors}}" wx:key="*this"
                  class="color-circle {{form.color===item?'color-selected':''}}"
                  style="background:{{item}};"
                  bindtap="selectColor" data-color="{{item}}">
              <text wx:if="{{form.color===item}}" class="check-mark">✓</text>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-ghost"   style="flex:1;" bindtap="closeModal">取消</button>
        <button class="btn-primary" style="flex:2;" bindtap="submitForm">{{isEdit ? '保存' : '创建'}}</button>
      </view>
    </view>
  </view>
</view>
