{
  "name": "focuslab",
  "version": "1.0.0",
  "main": "app.js",
  "scripts": {
    "test": "jest --coverage --testPathPatterns=__tests__",
    "test:e2e": "jest --testPathPatterns=__e2e__ --testTimeout=120000 --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/__e2e__/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "utils/**/*.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "miniprogram-automator": "^0.12.1",
    "miniprogram-simulate": "^1.6.1"
  }
}
